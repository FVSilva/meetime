# Meetime
MEETIME_API_TOKEN=seu_token_aqui
MEETIME_WEBHOOK_SECRET=sua_secret_aqui

# OpenAI (Whisper para transcrição)
OPENAI_API_KEY=sk-...

# Anthropic (Claude para resumo e feedback)
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API (WhatsApp) - https://evolution-api.com
# Pode ser self-hosted ou cloud (ex: https://api.seudominio.com.br)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_api_key
EVOLUTION_INSTANCE=nome-da-instancia

# Números dos SDRs para notificação WhatsApp (separados por vírgula, DDI+DDD+numero: 5511999999999)
# Só notifica se o owner do lead tiver @v4 no email
NOTIF_PHONES=5511999999999,5511888888888

# Google Chat Webhook
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXXX/messages?key=...

# Servidor
PORT=3001
FRONTEND_URL=http://localhost:5173
